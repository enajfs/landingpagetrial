<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>FreelanceFlow | Professional Freelancing Services</title>
  <!-- Google Fonts + simple reset -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: #fefefe;
      color: #1a1e2b;
      scroll-behavior: smooth;
      line-height: 1.5;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* header / nav */
    header {
      background: white;
      box-shadow: 0 8px 20px rgba(0,0,0,0.02), 0 2px 6px rgba(0,0,0,0.05);
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(2px);
      background: rgba(255,255,255,0.96);
    }

    .nav-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 0;
      flex-wrap: wrap;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #2563eb, #7c3aed);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      font-weight: 500;
      color: #2d3a5e;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #2563eb;
    }

    .btn-primary {
      background: #2563eb;
      color: white;
      padding: 10px 24px;
      border-radius: 40px;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s;
      display: inline-block;
      border: none;
      cursor: pointer;
      font-size: 0.95rem;
    }

    .btn-primary:hover {
      background: #1d4ed8;
      transform: translateY(-2px);
      box-shadow: 0 10px 20px -8px rgba(37,99,235,0.3);
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid #2563eb;
      color: #2563eb;
      padding: 9px 23px;
      border-radius: 40px;
      font-weight: 600;
      text-decoration: none;
      transition: 0.2s;
      display: inline-block;
    }

    .btn-outline:hover {
      background: #2563eb10;
      transform: translateY(-2px);
    }

    /* hero section */
    .hero {
      padding: 80px 0 70px;
    }
    .hero-grid {
      display: flex;
      align-items: center;
      gap: 40px;
      flex-wrap: wrap;
    }
    .hero-content {
      flex: 1;
    }
    .hero-badge {
      background: #e0e7ff;
      color: #1e40af;
      display: inline-block;
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 20px;
    }
    .hero-content h1 {
      font-size: 3.2rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 18px;
      letter-spacing: -0.02em;
      color: #0f172a;
    }
    .hero-highlight {
      color: #2563eb;
      border-bottom: 3px solid #93c5fd;
    }
    .hero-desc {
      font-size: 1.1rem;
      color: #334155;
      margin-bottom: 32px;
      max-width: 500px;
    }
    .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .hero-stats {
      margin-top: 40px;
      display: flex;
      gap: 32px;
    }
    .stat span {
      font-size: 1.8rem;
      font-weight: 800;
      display: block;
      color: #0f172a;
    }
    .hero-visual {
      flex: 1;
      background: linear-gradient(145deg, #2563eb08, #7c3aed08);
      border-radius: 48px;
      padding: 20px;
      text-align: center;
    }
    .hero-visual svg {
      max-width: 100%;
      height: auto;
    }

    /* section titles */
    .section-title {
      font-size: 2.2rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 50px;
      color: #0f172a;
    }
    .section-sub {
      text-align: center;
      color: #4b5563;
      margin-top: -10px;
      margin-bottom: 45px;
    }

    /* services */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 32px;
      margin: 40px 0 30px;
    }
    .service-card {
      background: white;
      border-radius: 28px;
      padding: 32px 24px;
      box-shadow: 0 20px 30px -15px rgba(0,0,0,0.05);
      transition: all 0.25s;
      border: 1px solid #f0f2f5;
    }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 30px 40px -18px rgba(0,0,0,0.15);
      border-color: #cbd5e1;
    }
    .service-icon {
      font-size: 2.8rem;
      margin-bottom: 20px;
    }
    .service-card h3 {
      font-size: 1.5rem;
      margin-bottom: 12px;
    }
    .service-card p {
      color: #475569;
    }

    /* about / testimonial */
    .about-wrap {
      background: #f8fafc;
      border-radius: 48px;
      padding: 50px 40px;
      margin: 40px 0;
    }
    .about-flex {
      display: flex;
      gap: 48px;
      align-items: center;
      flex-wrap: wrap;
    }
    .about-text {
      flex: 1.2;
    }
    .about-text h3 {
      font-size: 1.8rem;
      margin-bottom: 16px;
    }
    .about-text p {
      margin-bottom: 20px;
      color: #334155;
    }
    .skill-badge {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }
    .skill-badge span {
      background: white;
      padding: 6px 16px;
      border-radius: 40px;
      font-weight: 500;
      font-size: 0.85rem;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .testimonial-card {
      background: white;
      border-radius: 32px;
      padding: 32px;
      margin: 20px 0;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
      box-shadow: 0 12px 24px -12px rgba(0,0,0,0.08);
    }
    .testimonial-text {
      font-size: 1.15rem;
      font-style: italic;
      color: #1e293b;
    }
    .client-name {
      margin-top: 20px;
      font-weight: 700;
    }

    /* contact */
    .contact-form {
      max-width: 620px;
      margin: 0 auto;
      background: white;
      padding: 40px 32px;
      border-radius: 48px;
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.08);
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-group input, .form-group textarea {
      width: 100%;
      padding: 14px 18px;
      border: 1px solid #e2e8f0;
      border-radius: 28px;
      font-family: inherit;
      font-size: 1rem;
      transition: 0.2s;
      background: #fefefe;
    }
    .form-group input:focus, .form-group textarea:focus {
      outline: none;
      border-color: #2563eb;
      box-shadow: 0 0 0 3px #2563eb20;
    }
    button[type="submit"] {
      width: 100%;
      background: #2563eb;
      border: none;
      padding: 14px;
      font-weight: 700;
      font-size: 1rem;
      border-radius: 40px;
      cursor: pointer;
      transition: 0.2s;
    }
    footer {
      background: #0f172a;
      color: #cbd5e1;
      text-align: center;
      padding: 40px 20px;
      margin-top: 70px;
    }
    @media (max-width: 768px) {
      .hero-content h1 { font-size: 2.3rem; }
      .nav-links { gap: 20px; }
      .section-title { font-size: 1.8rem; }
      .hero-grid { flex-direction: column-reverse; text-align: center; }
      .hero-desc { margin-left: auto; margin-right: auto; }
      .hero-buttons { justify-content: center; }
      .hero-stats { justify-content: center; }
      .about-flex { flex-direction: column; text-align: center; }
      .skill-badge { justify-content: center; }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <div class="nav-bar">
        <div class="logo">⚡ FreelanceFlow</div>
        <ul class="nav-links">
          <li><a href="#home">Home</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
        <a href="#contact" class="btn-primary" style="padding: 8px 20px;">Hire Me →</a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero section -->
    <section id="home">
      <div class="container hero">
        <div class="hero-grid">
          <div class="hero-content">
            <div class="hero-badge">✨ top-rated freelancer</div>
            <h1>Build <span class="hero-highlight">digital products</span> that scale & shine</h1>
            <p class="hero-desc">I craft high‑performance websites, web apps, and brand experiences. Fast, modern, and tailored for your business.</p>
            <div class="hero-buttons">
              <a href="#contact" class="btn-primary">Start a project →</a>
              <a href="#services" class="btn-outline">Explore services</a>
            </div>
            <div class="hero-stats">
              <div class="stat"><span>50+</span> projects</div>
              <div class="stat"><span>98%</span> client satisfaction</div>
              <div class="stat"><span>24/7</span> support</div>
            </div>
          </div>
          <div class="hero-visual">
            <svg width="280" height="240" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="40" y="80" width="320" height="180" rx="28" fill="#EFF6FF" stroke="#2563eb" stroke-width="2"/>
              <circle cx="120" cy="150" r="20" fill="#3b82f6" fill-opacity="0.2" stroke="#2563eb" stroke-width="1.5"/>
              <circle cx="280" cy="150" r="20" fill="#a855f7" fill-opacity="0.2" stroke="#7c3aed" stroke-width="1.5"/>
              <path d="M160 190 L240 190 L200 230 L160 190Z" fill="#2563eb" fill-opacity="0.2" stroke="#2563eb"/>
              <line x1="200" y1="100" x2="200" y2="80" stroke="#2563eb" stroke-width="2"/>
              <circle cx="200" cy="70" r="6" fill="#2563eb"/>
              <text x="180" y="270" fill="#0f172a" font-weight="500" font-size="14">Full‑stack • UI/UX • Performance</text>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services">
      <div class="container">
        <h2 class="section-title">What I deliver</h2>
        <p class="section-sub">End‑to‑end freelancing solutions tailored to your goals</p>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon">🌐</div>
            <h3>Websites & Landing Pages</h3>
            <p>Custom, responsive, SEO-friendly websites that convert visitors into customers. From portfolios to business sites.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">⚙️</div>
            <h3>Web Apps & Dashboards</h3>
            <p>Interactive tools, admin panels, real‑time dashboards with modern frameworks (React, Vue, Node.js).</p>
          </div>
          <div class="service-card">
            <div class="service-icon">🎨</div>
            <h3>UI/UX Design</h3>
            <p>Beautiful, user‑friendly interfaces, wireframes, and prototyping. Designed to delight and engage.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">🚀</div>
            <h3>Performance & Optimization</h3>
            <p>Speed audits, Core Web Vitals, SEO improvements — make your site fly on all devices.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- About + testimonials -->
    <div class="container">
      <div class="about-wrap" id="about">
        <div class="about-flex">
          <div class="about-text">
            <h3>👋 I'm Alex — freelance developer & designer</h3>
            <p>With 6+ years of experience working with startups and agencies, I turn complex ideas into elegant, high‑performance digital experiences. I believe great code and thoughtful design go hand in hand.</p>
            <p>My workflow is transparent, agile, and client‑first. Every project includes responsive design, clean documentation, and ongoing support.</p>
            <div class="skill-badge">
              <span>React / Next.js</span><span>Vue / Nuxt</span><span>Python / Django</span><span>Node.js</span><span>TailwindCSS</span><span>Figma</span>
            </div>
          </div>
          <div style="flex:0.8;">
            <div class="testimonial-card" style="margin:0;">
              <div class="testimonial-text">“Alex redesigned our entire platform and increased conversion by 40% within two months. Absolute pro, great communication, and unmatched speed.”</div>
              <div class="client-name">— Sarah Chen, Founder of Lumina</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Second testimonial extra (client love) -->
    <div class="container">
      <div style="margin: 30px 0 20px;">
        <h2 class="section-title" style="margin-bottom: 20px;">What clients say 💬</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 24px; justify-content: center;">
          <div class="testimonial-card" style="margin:0; flex:1; min-width: 240px;">
            <div class="testimonial-text">“Fast turnaround, pixel perfect implementation. He understood our vision right away. Will hire again.”</div>
            <div class="client-name">— Michael R., CTO</div>
          </div>
          <div class="testimonial-card" style="margin:0; flex:1; min-width: 240px;">
            <div class="testimonial-text">“Deep technical knowledge + creative flair. The landing page he built for us is stunning and outperforms our old site 3x.”</div>
            <div class="client-name">— Priya K., Marketing Lead</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact + Form -->
    <section id="contact">
      <div class="container" style="margin-top: 50px;">
        <h2 class="section-title">Let's work together</h2>
        <p class="section-sub">Got a project in mind? Let's turn your idea into reality.</p>
        <div class="contact-form">
          <form id="freelance-contact-form">
            <div class="form-group">
              <input type="text" id="name" placeholder="Full name *" required>
            </div>
            <div class="form-group">
              <input type="email" id="email" placeholder="Email address *" required>
            </div>
            <div class="form-group">
              <input type="text" id="project" placeholder="Project type (website / web app / design)">
            </div>
            <div class="form-group">
              <textarea rows="4" id="message" placeholder="Tell me about your vision, timeline, or any details... *" required></textarea>
            </div>
            <button type="submit" class="btn-primary" style="width:100%; border: none;">Send message →</button>
            <p style="font-size: 0.8rem; text-align: center; margin-top: 16px; color: #4b5563;">I’ll reply within 24h. No spam, guaranteed.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p>© 2025 FreelanceFlow — High‑quality freelancing for modern businesses. </p>
      <p style="margin-top: 12px; font-size: 0.85rem;">📍 Based globally · Remote friendly · Always open to new challenges</p>
    </div>
  </footer>

  <script>
    // Smooth scroll for all anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href === "#" || href === "") return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    // Contact form handling (simple alert + console)
    const contactForm = document.getElementById('freelance-contact-form');
    if (contactForm) {
      contactForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const name = document.getElementById('name')?.value.trim();
        const email = document.getElementById('email')?.value.trim();
        const message = document.getElementById('message')?.value.trim();

        if (!name || !email || !message) {
          alert('❌ Please fill in all required fields (name, email, message).');
          return;
        }
        if (!email.includes('@') || !email.includes('.')) {
          alert('⚠️ Please enter a valid email address.');
          return;
        }

        // Simulate successful submission (you can replace with actual fetch to backend)
        alert(`✨ Thanks ${name}! Your message has been sent. I’ll get back to you shortly.`);
        contactForm.reset();
      });
    }
  </script>
</body>
</html>
